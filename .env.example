# =============================================================================
# Animetor Eval — 環境変数設定ファイル
#
# このファイルを .env にコピーして値を設定してください。
# cp .env.example .env
#
# 優先順位: シェル環境変数 > .env ファイル > コード内デフォルト値
# 別の .env ファイルを使う場合は ANIMETOR_ENV_FILE で指定。
# =============================================================================

# =============================================================================
# パス設定  (デフォルト: プロジェクトルート以下の result/ ディレクトリ)
# =============================================================================

# SQLite DB ファイルパス
# ANIMETOR_DB_PATH=result/db/animetor_eval.db

# JSON パイプライン出力ディレクトリ
# ANIMETOR_JSON_DIR=result/json

# レポート HTML 出力ディレクトリ
# ANIMETOR_REPORTS_DIR=result/reports

# HTML / 静的ファイル出力ディレクトリ
# ANIMETOR_HTML_DIR=result/html

# データディレクトリ (スクレイピングデータ等)
# ANIMETOR_DATA_DIR=data

# 別の .env ファイルを使う場合に指定 (絶対パス推奨)
# ANIMETOR_ENV_FILE=/path/to/custom.env

# =============================================================================
# スクレイピング
# =============================================================================

# AniList API アクセストークン (なければ匿名: 30 req/min)
# 取得: https://anilist.co/settings/developer
ANILIST_ACCESS_TOKEN=

# TMDB v4 read access token (Bearer 認証、推奨)
# 取得: https://www.themoviedb.org/settings/api
# Rate limit: 50 req/sec
TMDB_BEARER=

# TMDB v3 API key (フォールバック、query param 認証)
# v4 Bearer がある場合は不要
# TMDB_API_KEY=

# リクエスト間の待機時間 (秒) — seesaawiki 等
# ANIMETOR_SCRAPE_DELAY=1.0

# チェックポイント間隔 (N件ごとにDBコミット)
# ANIMETOR_SCRAPE_CHECKPOINT_INTERVAL=3

# 最大リトライ回数
# ANIMETOR_SCRAPE_MAX_RETRIES=3

# =============================================================================
# 分析パラメータ
# =============================================================================

# --- BiRank ---
# ANIMETOR_BIRANK_ALPHA=0.85
# ANIMETOR_BIRANK_BETA=0.85
# ANIMETOR_BIRANK_MAX_ITER=100
# ANIMETOR_BIRANK_TOL=1e-6
# ANIMETOR_BIRANK_ROLE_DAMPING=0.5   # 0.0=役職無視, 1.0=フル階層

# --- AKM (固定効果推定) ---
# ANIMETOR_AKM_MAX_ITER=50
# ANIMETOR_AKM_TOL=1e-8
# ANIMETOR_AKM_MIN_MOVER_FRACTION=0.10

# --- 非活動ペナルティ (Dormancy) ---
# ANIMETOR_DORMANCY_DECAY_RATE=0.5   # 半減期 (1年で50%減)
# ANIMETOR_DORMANCY_GRACE_PERIOD=2.0  # 猶予期間 (年)

# --- PageRank ---
# ANIMETOR_PAGERANK_DAMPING=0.85
# ANIMETOR_PAGERANK_MAX_ITER=100
# ANIMETOR_PAGERANK_TOL=1e-6

# --- スコア正規化 ---
# ANIMETOR_NORMALIZATION_METHOD=minmax  # minmax | percentile | zscore

# --- Integrated Value ---
# ANIMETOR_IV_CV_FOLDS=5
# ANIMETOR_IV_CV_SEED=42

# --- 作品の長さ補正 ---
# ANIMETOR_DURATION_BASELINE_MINUTES=30   # 基準 (30分アニメ = 1.0x)
# ANIMETOR_DURATION_MAX_MULTIPLIER=2.0    # 映画等の上限

# =============================================================================
# API サーバー
# =============================================================================

# 書き込みエンドポイントの保護 (未設定 = dev モード、認証なし)
API_SECRET_KEY=

# GET レスポンスの Cache-Control max-age (秒)
# API_CACHE_MAX_AGE=300

# UI 言語 (ja | en)
# ANIMETOR_LANG=ja

# =============================================================================
# LLM / AI エンティティ解決 (有効化: ANIMETOR_LLM=1)
# =============================================================================

# 有効化フラグ (0=無効, 1=有効)
# ANIMETOR_LLM=0

# API ベース URL (Ollama デフォルト)
# ANIMETOR_LLM_BASE_URL=http://localhost:11434/v1

# モデル名
# ANIMETOR_LLM_MODEL=qwen3:32b

# 生成温度 (低いほど決定論的)
# ANIMETOR_LLM_TEMPERATURE=0.1

# 最大トークン数
# ANIMETOR_LLM_MAX_TOKENS=500

# タイムアウト (秒)
# ANIMETOR_LLM_TIMEOUT=30.0

# バッチサイズ (1プロンプトあたりの件数)
# ANIMETOR_LLM_BATCH_SIZE=30

# =============================================================================
# Neo4j (オプション — graph export 機能)
# =============================================================================
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
