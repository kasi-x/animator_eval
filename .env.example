# Animetor Eval — Environment Variables
# Copy this file to .env and fill in your values.
# All variables are optional unless noted.

# ── AniList API ──────────────────────────────────────────────
# OAuth access token for higher rate limits (optional)
# Without this, anonymous rate limits apply (90 req/min)
ANILIST_ACCESS_TOKEN=

# ── API Security ─────────────────────────────────────────────
# Secret key to protect write endpoints (e.g. /api/pipeline/run)
# If not set, write endpoints are open (dev mode)
API_SECRET_KEY=

# Comma-separated list of allowed CORS origins
# Default: http://localhost:3000,http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Neo4j (optional) ────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Internationalization ─────────────────────────────────────
# Language override: "en" or "ja" (auto-detected from system locale if unset)
ANIMETOR_LANG=

# ── AI-assisted Entity Resolution (optional) ─────────────────
# Uses local Ollama instance — no external API calls
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_NAME=qwen3:8b
